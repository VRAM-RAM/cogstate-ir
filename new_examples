#!/bin/zsh

count=${1:?Usage: $0 <number of examples>}
data="data"

mkdir -p "$data"

last=0
for dir in "$data"/example_*(/N); do
    n="${dir##*example_}"
    [[ "$n" =~ ^[0-9]+$ ]] && (( 10#$n > last )) && last=$((10#$n))
done

for ((i = last + 1; i <= last + count; i++)); do
    d=$(printf "$data/example_%02d" "$i")
    mkdir -p "$d"
    touch "$d/input.yaml" "$d/output.yaml"
    echo "  $d"
done
echo "Created $count example(s), starting at example_$(printf '%02d' $((last + 1)))"
